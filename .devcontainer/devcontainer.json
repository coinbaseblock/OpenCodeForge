{
  "name": "OpenCodeForge Workspace",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "code-server",
  "workspaceFolder": "/home/coder/workspace",
  "remoteUser": "root",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers"
      ]
    }
  },
  "forwardPorts": [3000, 8088, 8443, 11434]
}

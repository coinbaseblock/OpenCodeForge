# OpenCodeForge environment configuration
# Copy this file to .env and adjust values to your environment.

# --- Ports -------------------------------------------------------------------
OLLAMA_PORT=11434
WEBUI_PORT=3000
TOOLS_PORT=8088
CODE_SERVER_PORT=8443

# --- Workspace ---------------------------------------------------------------
# Host path mounted into tools-api, code-server, and the indexer.
# Defaults to ./workspace inside the repo. Override to point at any directory.
#
# Linux / macOS / WSL2:
#   WORKSPACE_HOST_DIR=/home/you/projects
# Windows Docker Desktop (native path, use forward slashes):
#   WORKSPACE_HOST_DIR=C:/Users/you/projects
# Windows WSL2 distro path (when running compose from inside WSL):
#   WORKSPACE_HOST_DIR=/mnt/c/Users/you/projects
WORKSPACE_HOST_DIR=./workspace

# --- code-server (browser VS Code) -------------------------------------------
# Auth mode: "password" (default) or "none" (open; only safe on localhost).
CODE_SERVER_AUTH=password
# Login password when CODE_SERVER_AUTH=password. Change before exposing!
CODE_SERVER_PASSWORD=opencodeforge

# --- Ollama runtime ----------------------------------------------------------
# Keep models loaded in memory between requests. Lower if RAM is tight.
OLLAMA_KEEP_ALIVE=30m
# Concurrent generations per model. 1 is safest for CPU-only.
OLLAMA_NUM_PARALLEL=1
# How many models can be resident at the same time.
OLLAMA_MAX_LOADED_MODELS=1

# --- Open WebUI --------------------------------------------------------------
# Set to true to require login. Default is false for single-user local setups.
WEBUI_AUTH=false
DEFAULT_USER_ROLE=admin

# --- Tools API ---------------------------------------------------------------
# When true, tools-api enforces the command allowlist and the path sandbox.
SAFE_MODE=true
# Comma-separated list of commands that POST /run is allowed to execute.
# Each entry is matched as a literal prefix on the command line.
ALLOWED_COMMANDS=go test ./...,go build ./...,npm test,npm run build,python -m pytest,docker compose config
